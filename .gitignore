# Root ignore for the whole project

# Node modules (covers both backend and frontend)
**/node_modules/

# Environment variables (secrets)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Production builds
**/dist/
**/build/

# IDE settings
.vscode/
.idea/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
